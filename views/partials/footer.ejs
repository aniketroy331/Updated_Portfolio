<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Footer</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <link rel="stylesheet" href="/css/footer.css">
</head>
<body>
    <footer class="footer">
        <div class="footer-content">
          <div class="footer-section about">
            <h2 class="logo-text">Aniket Roy</h2>
            <!-- <p>
              A passionate designer and developer dedicated to creating beautiful and functional websites. Let's build something amazing together!
            </p> -->
            <div class="contact">
              <span><i class="fas fa-phone"></i> &nbsp; +123-456-7890</span>
              <span><i class="fas fa-envelope"></i> &nbsp; yourname@example.com</span>
            </div>
            <div class="socials">
              <a href="#"><i class="fab fa-linkedin"></i></a>
              <a href="#"><i class="fab fa-github"></i></a>
              <a href="#"><i class="fab fa-twitter"></i></a>
              <a href="#"><i class="fab fa-instagram"></i></a>
            </div>
          </div>
      
          <div class="footer-section links">
            <h2>Quick Links</h2>
            <ul>
              <li><a href="#">Home</a></li>
              <li><a href="#">About</a></li>
              <li><a href="#">Portfolio</a></li>
              <li><a href="#">Services</a></li>
              <li><a href="#">Contact</a></li>
            </ul>
          </div>
      
          <div class="footer-section contact-form">
            <h2>Get in Touch</h2>
            <form action="#" method="post">
              <input type="email" name="email" class="text-input contact-input" placeholder="Your email address">
              <textarea name="message" class="text-input contact-input" placeholder="Your message"></textarea>
              <button type="submit" class="btn btn-big">
                <i class="fas fa-envelope"></i> Send
              </button>
            </form>
          </div>
        </div>
      
        <div class="footer-bottom">
          &copy; All Copyrights reserved || 2025 || Designed by Aniket Roy.
        </div>
      </footer>
  <script src="/js/footer.js"></script>
</body>
</html>